<?xml version="1.0" encoding="UTF-8"?>
<web-app
    xmlns="https://jakarta.ee/xml/ns/jakartaee"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
    version="6.0">

  <display-name>GLearn Portal Case Study</display-name>

  <welcome-file-list>
    <welcome-file>login.html</welcome-file>
  </welcome-file-list>

  <filter>
    <filter-name>AuthFilter</filter-name>
    <filter-class>com.glearnportal.web.AuthFilter</filter-class>
  </filter>

  <filter-mapping>
    <filter-name>AuthFilter</filter-name>
    <url-pattern>/*</url-pattern>
  </filter-mapping>

  <servlet>
    <servlet-name>RegisterServlet</servlet-name>
    <servlet-class>com.glearnportal.web.RegisterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>RegisterServlet</servlet-name>
    <url-pattern>/register</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LoginServlet</servlet-name>
    <servlet-class>com.glearnportal.web.LoginServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/login</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LoginServlet</servlet-name>
    <url-pattern>/api/login</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>LogoutServlet</servlet-name>
    <servlet-class>com.glearnportal.web.LogoutServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/logout</url-pattern>
  </servlet-mapping>
  <servlet-mapping>
    <servlet-name>LogoutServlet</servlet-name>
    <url-pattern>/api/logout</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MeServlet</servlet-name>
    <servlet-class>com.glearnportal.web.MeServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MeServlet</servlet-name>
    <url-pattern>/api/me</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>CoursesXmlServlet</servlet-name>
    <servlet-class>com.glearnportal.web.CoursesXmlServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>CoursesXmlServlet</servlet-name>
    <url-pattern>/api/courses.xml</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AnnouncementsXmlServlet</servlet-name>
    <servlet-class>com.glearnportal.web.AnnouncementsXmlServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AnnouncementsXmlServlet</servlet-name>
    <url-pattern>/api/announcements.xml</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>AttendanceUpdateServlet</servlet-name>
    <servlet-class>com.glearnportal.web.AttendanceUpdateServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>AttendanceUpdateServlet</servlet-name>
    <url-pattern>/api/attendance/update</url-pattern>
  </servlet-mapping>

  <servlet>
    <servlet-name>MarksUpdateServlet</servlet-name>
    <servlet-class>com.glearnportal.web.MarksUpdateServlet</servlet-class>
  </servlet>
  <servlet-mapping>
    <servlet-name>MarksUpdateServlet</servlet-name>
    <url-pattern>/api/marks/update</url-pattern>
  </servlet-mapping>
</web-app>
